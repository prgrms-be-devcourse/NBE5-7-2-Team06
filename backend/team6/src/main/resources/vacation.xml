<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://xmlns.jcp.org/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence/orm
					http://xmlns.jcp.org/xml/ns/persistence/orm_2_2.xsd" version="2.2">

    <!--
    type_code: 1=연차, 2=병가, 3=반차
    status_code: 1=대기, 2=승인, 3=반려
    를 가정하여 작성하였습니다 만약 code가 변경된다면 수정해야 합니다.
    추후 계산로직을 어플리케이션단에서 하는 식으로 변경해야 할 수 있음
     -->
    <named-native-query name="VacationRequest.getMonthlyVacationStatistics" result-set-mapping="VacationMonthlyStatisticsResponseMapping">
        <query><![CDATA[
        WITH preprocessed AS (
            SELECT
                member_id,
                MONTH(from_date) AS start_month,
                MONTH(to_date) AS end_month,
                from_date,
                to_date,
                type_code
            FROM
                vacation_request
            WHERE
                status_code = 2 AND YEAR(from_date) = :target_year
        ),
        vacation_summary AS (
            SELECT
                member_id,
                SUM(
                    CASE
                        WHEN start_month = 1
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN
                                            0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 1
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `january`,
                SUM(
                    CASE
                        WHEN start_month = 2
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 2
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `february`,
                SUM(
                    CASE
                        WHEN start_month = 3
                           THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 3
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `march`,
                SUM(
                    CASE
                        WHEN start_month = 4
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 4
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE 0
                    END
                ) AS `april`,
                SUM(
                    CASE
                        WHEN start_month = 5
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 5
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE 0
                    END
                ) AS `may`,
                SUM(
                    CASE
                        WHEN start_month = 6
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 6
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `june`,
                SUM(
                    CASE
                        WHEN start_month = 7
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 7
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `july`,
                SUM(
                    CASE
                        WHEN start_month = 8
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 8
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `august`,
                SUM(
                    CASE
                        WHEN start_month = 9
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 9
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `september`,
                SUM(
                    CASE
                        WHEN start_month = 10
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 10
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `october`,
                SUM(
                    CASE
                        WHEN start_month = 11
                            THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 11
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `november`,
                SUM(
                    CASE
                        WHEN start_month = 12
                             THEN
                                CASE
                                    WHEN type_code = 3
                                        THEN 0.5
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date,from_date) + 1
                                    ELSE
                                        DATEDIFF(last_day(from_date) , from_date) + 1
                                END
                        WHEN end_month = 12
                            THEN
                                CASE
                                    WHEN start_month = end_month
                                        THEN
                                            DATEDIFF(to_date, from_date) + 1
                                    ELSE
                                        DAY(to_date)
                                END
                        ELSE
                            0
                    END
                ) AS `december`
            FROM
                preprocessed
            GROUP BY
                member_id
        ),vacation_info_preprocessed AS(
            SELECT
                member_id,
                SUM(total_count) as total_count,
                SUM(use_count) as use_count,
                SUM(remain_count) as remain_count
            FROM
                vacation_info
            WHERE
                member_id in (select member_id from vacation_summary)
            GROUP BY
                member_id
        )
        SELECT
            m.member_id as memberId,
            m.name as userName,
            vi.total_count as totalCount,
            vi.use_count as useCount,
            vi.remain_count as remainCount,
            vs.`january` as january,
            vs.`february` as february,
            vs.`march` as march,
            vs.`april` as april,
            vs.`may` as may,
            vs.`june` as june,
            vs.`july` as july,
            vs.`august` as august,
            vs.`september` as september,
            vs.`october` as october,
            vs.`november` as november,
            vs.`december` as december

        FROM
            vacation_summary vs
        JOIN
            member m
        JOIN
            vacation_info_preprocessed vi
        ON
            m.member_id = vs.member_id and vi.member_id = m.member_id
        limit :limit
        offset :offset
        ]]></query>
    </named-native-query>
    <sql-result-set-mapping name="VacationMonthlyStatisticsResponseMapping">
        <constructor-result target-class="programmers.team6.domain.vacation.dto.VacationMonthlyStatisticsResponse">
            <column name="memberId" />
            <column name="userName" />
            <column name="totalCount" class="java.lang.Long"/>
            <column name="useCount" class="java.lang.Long"/>
            <column name="remainCount" class="java.lang.Long"/>
            <column name="january" class="java.lang.Long"/>
            <column name="february" class="java.lang.Long"/>
            <column name="march" class="java.lang.Long"/>
            <column name="april" class="java.lang.Long"/>
            <column name="may" class="java.lang.Long"/>
            <column name="june" class="java.lang.Long"/>
            <column name="july" class="java.lang.Long"/>
            <column name="august" class="java.lang.Long"/>
            <column name="september" class="java.lang.Long"/>
            <column name="october" class="java.lang.Long"/>
            <column name="november" class="java.lang.Long"/>
            <column name="december" class="java.lang.Long"/>
        </constructor-result>
    </sql-result-set-mapping>
</entity-mappings>